{
    "multipart": [
        {   "when": { "up": "true" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_post_lime" }
        },
        {   "when": { "north": "low" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_lime", "uvlock": true }
        },
        {   "when": { "north": "tall" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_tall_lime", "uvlock": true }
        },
        {   "when": { "east": "low" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_lime", "y": 90, "uvlock": true }
        },
        {   "when": { "east": "tall" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_tall_lime", "y": 90, "uvlock": true }
        },
        {   "when": { "south": "low" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_lime", "y": 180, "uvlock": true }
        },
        {   "when": { "south": "tall" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_tall_lime", "y": 180, "uvlock": true }
        },
        {   "when": { "west": "low" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_lime", "y": 270, "uvlock": true }
        },
        {   "when": { "west": "tall" },
            "apply": { "model": "gwycraft:block/dyed_cobblestone_wall_side_tall_lime", "y": 270, "uvlock": true }
        }
    ]
}
